# ─── RAILWAY (backend API) ───────────────────────────────────────────────────
# Copy these into your Railway service → Variables tab

NODE_ENV=production

# Neon PostgreSQL — copy the connection string from neon.tech dashboard
DATABASE_URL=postgresql://user:pass@ep-xxx.region.aws.neon.tech/dbname?sslmode=require

# Your Vercel frontend URL (tells the server to skip static file serving + sets CORS)
FRONTEND_URL=https://your-project.vercel.app

# Your Railway public URL (used for Stripe webhook + email links)
# Set this AFTER your first Railway deploy — copy from Railway dashboard
PUBLIC_URL=https://your-project.up.railway.app

# Firebase Admin SDK — paste the full JSON from Firebase Console >
# Project Settings > Service Accounts > Generate new private key
# Remove all newlines before pasting (it must be on a single line)
FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"..."}

# Resend (optional — for sending proposal/invoice emails)
RESEND_API_KEY=re_xxxxxxxxxxxx

# Stripe (optional — paste your secret key from dashboard.stripe.com/apikeys)
# STRIPE_SECRET_KEY=sk_live_xxxxxxxxxxxx


# ─── VERCEL (frontend) ───────────────────────────────────────────────────────
# Add these in Vercel dashboard → Project Settings → Environment Variables

# Points the frontend to your Railway API (no trailing slash)
VITE_API_URL=https://your-project.up.railway.app

# Firebase client-side config — from Firebase Console > Project Settings > Your apps
VITE_FIREBASE_API_KEY=AIzaSy...
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_APP_ID=1:123456789:web:abc123
