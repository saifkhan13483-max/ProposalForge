# ─── Railway (backend) environment variables ──────────────────────────────────

# PostgreSQL connection string from Neon (copy from your Neon project dashboard)
# Format: postgresql://user:password@host/dbname?sslmode=require
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# Node environment — must be "production" on Railway
NODE_ENV=production

# Railway injects PORT automatically — do NOT set this manually on Railway
# PORT=3000

# Firebase service account JSON (single line — copy from Google Cloud Console → Service Accounts)
# Remove all newlines before pasting
FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"..."}

# AI proposal generation — get from https://aistudio.google.com/app/apikey
GEMINI_API_KEY=AIza...

# Transactional email — get from https://resend.com/api-keys (optional)
RESEND_API_KEY=re_...

# Your Vercel frontend URL (no trailing slash)
# Used for CORS — allows your frontend to call this backend
FRONTEND_URL=https://your-app.vercel.app

# Your Railway backend URL (no trailing slash)
# Used to build absolute URLs in emails and PDFs
# Set this AFTER your first Railway deploy — copy from Railway dashboard
PUBLIC_URL=https://your-app.up.railway.app

# Any long random string — used to sign JWTs
# Generate one with: openssl rand -base64 32
JWT_SECRET=your-very-long-random-secret

# Stripe secret key — get from https://dashboard.stripe.com/apikeys (optional)
STRIPE_SECRET_KEY=sk_live_...


# ─── Vercel (frontend) environment variables ──────────────────────────────────

# Your Railway backend URL (no trailing slash)
# Tells the frontend where to send API requests
VITE_API_URL=https://your-app.up.railway.app

# Firebase web app config — get from Firebase Console → Project settings → Your apps
VITE_FIREBASE_API_KEY=AIza...
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_APP_ID=1:123456789:web:abc123
