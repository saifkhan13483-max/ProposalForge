# ─── Render (backend) environment variables ───────────────────────────────────

# PostgreSQL connection string from Neon (copy from your Neon project dashboard)
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# Node environment — must be "production" on Render
NODE_ENV=production

# Port Render will listen on (Render sets this automatically; keep as 3000)
PORT=3000

# Firebase service account JSON (single-line, paste from Google Cloud Console)
FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account",...}

# AI proposal generation — get from https://aistudio.google.com/app/apikey
GEMINI_API_KEY=AIza...

# Transactional email — get from https://resend.com/api-keys (optional)
RESEND_API_KEY=re_...

# Your Vercel frontend URL (no trailing slash), e.g. https://proposalforge.vercel.app
# Comma-separate multiple domains if needed
FRONTEND_URL=https://your-app.vercel.app

# Auto-generated by Render (or paste any long random string)
JWT_SECRET=your-very-long-random-secret

# Stripe secret key — get from https://dashboard.stripe.com/apikeys (optional)
STRIPE_SECRET_KEY=sk_live_...


# ─── Vercel (frontend) environment variables ──────────────────────────────────

# Your Render backend URL (no trailing slash)
VITE_API_URL=https://proposalforge-api.onrender.com

# Firebase web app config — get from Firebase Console → Project settings → Your apps
VITE_FIREBASE_API_KEY=AIza...
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_APP_ID=1:123456789:web:abc123
