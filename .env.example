# ─────────────────────────────────────────────────────────────────────────────
# ProposalForge — Environment Variables Reference
# ─────────────────────────────────────────────────────────────────────────────
# For LOCAL DEV: copy this file to .env and fill in your values.
# For PRODUCTION: set these in each platform's dashboard (Railway / Vercel).
# Never commit your actual .env file to git.
# ─────────────────────────────────────────────────────────────────────────────


# ─── RAILWAY (backend API) ───────────────────────────────────────────────────
# Set these in your Railway service → Variables tab

NODE_ENV=production

# Neon PostgreSQL — copy the "Connection string" from neon.tech dashboard
# It must end with ?sslmode=require for Neon
DATABASE_URL=postgresql://user:pass@ep-xxx.region.aws.neon.tech/dbname?sslmode=require

# Your Vercel frontend URL — tells the server which origin to allow via CORS
# Also used for building client-facing links in emails (proposals/invoices)
# Comma-separate multiple URLs if needed: https://app.vercel.app,https://custom-domain.com
FRONTEND_URL=https://your-project.vercel.app

# Your Railway backend's own public URL — used for Stripe webhook registration
# Set this AFTER your first Railway deploy (copy the generated URL from the dashboard)
PUBLIC_URL=https://your-project.up.railway.app

# Firebase Admin SDK — for verifying Firebase ID tokens server-side
# Download from: Firebase Console → Project Settings → Service Accounts → Generate new private key
# IMPORTANT: Collapse the entire JSON to a single line (remove all newlines) before pasting
FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"...","private_key_id":"...","private_key":"-----BEGIN PRIVATE KEY-----\\n...\\n-----END PRIVATE KEY-----\\n","client_email":"firebase-adminsdk-xxx@your-project.iam.gserviceaccount.com","client_id":"...","auth_uri":"https://accounts.google.com/o/oauth2/auth","token_uri":"https://oauth2.googleapis.com/token","auth_provider_x509_cert_url":"https://www.googleapis.com/oauth2/v1/certs","client_x509_cert_url":"..."}

# Google Gemini — AI proposal generation
# Get your key from https://aistudio.google.com/app/apikey
GEMINI_API_KEY=AIzaSy...

# Resend — for sending proposal/invoice emails to clients (optional)
# Get your key from https://resend.com/api-keys
RESEND_API_KEY=re_xxxxxxxxxxxx

# Stripe — for Pro plan payments (optional, app works without it)
# Secret key: https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_live_xxxxxxxxxxxx
# Webhook secret: created when you add the webhook endpoint in Stripe dashboard
# Endpoint URL to register: https://your-project.up.railway.app/api/stripe/webhook
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxx

# Skip Puppeteer's Chromium download — PDF generation uses pdfmake, not Puppeteer
PUPPETEER_SKIP_CHROMIUM_DOWNLOAD=true


# ─── VERCEL (frontend) ───────────────────────────────────────────────────────
# Add these in Vercel dashboard → Project Settings → Environment Variables
# All VITE_ variables must be set BEFORE Vercel builds the frontend

# Points the frontend to your Railway API (no trailing slash)
VITE_API_URL=https://your-project.up.railway.app

# Firebase client-side config — from Firebase Console → Project Settings → Your apps
# (click "Add app" → Web if you haven't already)
VITE_FIREBASE_API_KEY=AIzaSy...
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_APP_ID=1:123456789:web:abc123


# ─── FIREBASE AUTHORIZED DOMAINS ─────────────────────────────────────────────
# Google sign-in (popup) requires your production domain to be whitelisted.
# Add both domains in: Firebase Console → Authentication → Settings → Authorized domains
#   • your-project.vercel.app   (your Vercel frontend)
#   • your-project.up.railway.app  (optional, only if testing auth directly on the API)
