# ─── RAILWAY (backend API) ───────────────────────────────────────────────────
# Copy these into your Railway service → Variables tab

NODE_ENV=production

# Neon PostgreSQL — copy the connection string from neon.tech dashboard
# Make sure to append ?sslmode=require at the end
DATABASE_URL=postgresql://user:pass@ep-xxx.region.aws.neon.tech/dbname?sslmode=require

# Your Vercel frontend URL (tells the server to skip static file serving + sets CORS)
# If you have multiple preview URLs, comma-separate them
FRONTEND_URL=https://your-project.vercel.app

# Your Railway public URL (used for Stripe webhook + email links in proposals/invoices)
# Set this AFTER your first Railway deploy — copy the generated URL from Railway dashboard
PUBLIC_URL=https://your-project.up.railway.app

# Port Railway will use (Railway sets PORT automatically — leave this out unless needed)
# SERVER_PORT=3000

# JWT secret — generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=replace_with_a_long_random_string

# Firebase Admin SDK — paste the full JSON from:
#   Firebase Console > Project Settings > Service Accounts > Generate new private key
# IMPORTANT: Collapse the JSON to a single line before pasting (remove all newlines)
FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"...","private_key_id":"...","private_key":"-----BEGIN PRIVATE KEY-----\\n...\\n-----END PRIVATE KEY-----\\n","client_email":"firebase-adminsdk-xxx@your-project.iam.gserviceaccount.com","client_id":"...","auth_uri":"https://accounts.google.com/o/oauth2/auth","token_uri":"https://oauth2.googleapis.com/token","auth_provider_x509_cert_url":"https://www.googleapis.com/oauth2/v1/certs","client_x509_cert_url":"..."}

# Gemini AI — get your key from https://aistudio.google.com/app/apikey
GEMINI_API_KEY=AIzaSy...

# Resend (optional — for sending proposal/invoice emails to clients)
# Get your key from https://resend.com/api-keys
RESEND_API_KEY=re_xxxxxxxxxxxx

# Stripe (optional — for Pro plan payments)
# Get your secret key from https://dashboard.stripe.com/apikeys
# STRIPE_SECRET_KEY=sk_live_xxxxxxxxxxxx


# ─── VERCEL (frontend) ───────────────────────────────────────────────────────
# Add these in Vercel dashboard → Project Settings → Environment Variables
# All VITE_ variables must be set BEFORE your Vercel build runs

# Points the frontend to your Railway API server (no trailing slash)
VITE_API_URL=https://your-project.up.railway.app

# Firebase client-side config — from Firebase Console > Project Settings > Your apps
# (click "Add app" → Web if you haven't already)
VITE_FIREBASE_API_KEY=AIzaSy...
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_APP_ID=1:123456789:web:abc123
VITE_FIREBASE_MESSAGING_SENDER_ID=123456789
VITE_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
