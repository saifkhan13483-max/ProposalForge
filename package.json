{
  "name": "proposalforge",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "node_modules/.bin/concurrently -n client,server -c cyan,yellow \"npm run dev:client\" \"npm run dev:server\"",
    "dev:client": "cd client && npm run dev",
    "dev:server": "node_modules/.bin/tsx watch server/index.ts",
    "build": "npm run build:client && npm run build:server",
    "build:client": "cd client && vite build",
    "build:server": "cd server && tsc",
    "codegen": "cd lib/api-spec && orval --config orval.config.ts",
    "db:push": "cd server && tsx schema.ts"
  },
