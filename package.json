{
  "name": "proposalforge",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently -n client,server -c cyan,yellow \"npm run dev:client\" \"npm run dev:server\"",
    "dev:client": "cd client && node_modules/.bin/vite --port 5000 --host",
    "dev:server": "node_modules/.bin/tsx watch server/index.ts",
    "build": "npm run build:client && npm run build:server",
    "build:client": "cd client && vite build",
    "build:server": "cd server && tsc",
    "codegen": "cd lib/api-spec && orval --config orval.config.ts",
    "db:push": "cd server && tsx schema.ts"
  },
  "dependencies": {
    "@google/generative-ai": "^0.21.0",
    "bcrypt": "^5.1.1",
    "cors": "^2.8.6",
    "dotenv": "^16.6.1",
    "express": "^4.22.1",
    "express-session": "^1.19.0",
    "groq-sdk": "^1.1.2",
    "jsonwebtoken": "^9.0.3",
    "multer": "^1.4.5-lts.1",
    "pdfmake": "^0.3.8",
    "pg": "^8.20.0",
    "puppeteer": "^22.15.0",
    "resend": "^3.5.0",
    "stripe": "^17.7.0",
    "stripe-replit-sync": "^1.0.0",
    "uuid": "^10.0.0"
  },
  "devDependencies": {
    "@types/bcrypt": "^5.0.2",
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.25",
    "@types/express-session": "^1.19.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/multer": "^1.4.13",
    "@types/node": "^22.19.17",
    "@types/pg": "^8.20.0",
    "@types/uuid": "^10.0.0",
    "concurrently": "^9.2.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "zod": "^4.4.3"
  }
}
